{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es2015",
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "noImplicitAny": true,
    "resolveJsonModule": true
  },
  "lib": ["es2015"],
  "exclude": ["src/**/*.test.ts"],
  "include": ["src/**/*.ts", "example/**/*.ts"]
}
